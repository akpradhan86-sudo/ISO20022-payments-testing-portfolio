  "item": [
    {
      "name": "Positive Scenarios",
      "item": [
        {
          "name": "Validate Valid pacs.008 Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"HTTP status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const responseJson = pm.response.json();\r",
                  "\r",
                  "const xmlString = responseJson.data;\r",
                  "\r",
                  "\r",
                  "pm.test(\"Response contains XML payload\", function () {\r",
                  "    pm.expect(xmlString).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"MsgId is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<MsgId>\");\r",
                  "    pm.expect(xmlString).to.include(\"</MsgId>\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"EndToEndId is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<EndToEndId>\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"UETR is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<UETR>\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Interbank settlement amount is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<IntrBkSttlmAmt\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Payment currency is USD\", function () {\r",
                  "    pm.expect(xmlString).to.include('Ccy=\"USD\"');\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Debtor name is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<Dbtr>\");\r",
                  "    pm.expect(xmlString).to.include(\"<Nm>\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Creditor is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<Cdtr>\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"BICFI is present\", function () {\r",
                  "    pm.expect(xmlString).to.include(\"<BICFI>\");\r",
                  "});\r",
                  "const msgIdMatch =\r",
                  "    xmlString.match(/<MsgId>(.*?)<\\/MsgId>/);\r",
                  "\r",
                  "pm.test(\"MsgId value can be extracted\", function () {\r",
                  "\r",
                  "    pm.expect(msgIdMatch).to.not.be.null;\r",
                  "\r",
                  "});\r",
                  "\r",
                  "if (msgIdMatch) {\r",
                  "\r",
                  "    pm.collectionVariables.set(\r",
                  "        \"lastMsgId\",\r",
                  "        msgIdMatch[1]\r",
                  "    );\r",
                  "\r",
                  "    console.log(\r",
                  "        \"Captured MsgId:\",\r",
                  "        msgIdMatch[1]\r",
                  "    );\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml",
                "type": "text"
              }
            ],
